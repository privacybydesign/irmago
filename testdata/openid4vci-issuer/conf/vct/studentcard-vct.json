{
  "path": "/vct/studentcard",
  "credentials": ["StudentCardCredentialSdJwt"],
  "document": {
    "name": "Student Card Credential (SD-JWT)",
    "description": "VCT metadata for student card SD-JWT credential",
    "language": "en",
    "display": [
      { "lang": "en", "name": "Student Card Credential (SD-JWT)" }
    ],
    "claims": [
      { "path": ["university"], "sd": "allowed" },
      { "path": ["level"], "sd": "allowed" },
      { "path": ["student_id"], "sd": "allowed" },
      { "path": ["courses"], "sd": "allowed" }
    ],
    "issuer": "{{ here }}"
  }
}
