{
  "path": "/vct/membership",
  "credentials": ["MembershipCredentialSdJwt"],
  "document": {
    "name": "Membership Credential (SD-JWT)",
    "description": "VCT metadata for membership SD-JWT credential with mixed SD/non-SD claims",
    "language": "en",
    "display": [
      { "locale": "en", "name": "Membership Credential (SD-JWT)" }
    ],
    "claims": [
      {
        "path": ["member_name"],
        "sd": "allowed",
        "display": [
          { "locale": "en", "label": "Member Name" },
          { "locale": "nl", "label": "Naam lid" }
        ]
      },
      {
        "path": ["member_since"],
        "display": [
          { "locale": "en", "label": "Member Since" },
          { "locale": "nl", "label": "Lid sinds" }
        ]
      },
      {
        "path": ["membership_type"],
        "sd": "allowed",
        "display": [
          { "locale": "en", "label": "Membership Type" },
          { "locale": "nl", "label": "Type lidmaatschap" }
        ]
      },
      {
        "path": ["benefits"]
      }
    ],
    "issuer": "{{ here }}"
  }
}
