{
  "path": "/vct/house",
  "credentials": ["HouseCredentialSdJwt"],
  "document": {
    "name": "House Possession Credential (SD-JWT)",
    "description": "VCT metadata for house possession SD-JWT credential",
    "language": "en",
    "display": [
      { "lang": "en", "name": "House Possession Credential (SD-JWT)" }
    ],
    "claims": [
      { "path": ["owner_name"], "sd": "allowed" },
      { "path": ["address"], "sd": "allowed" },
      { "path": ["address", "street"], "sd": "allowed" },
      { "path": ["address", "city"], "sd": "allowed" },
      { "path": ["address", "country"], "sd": "allowed" }
    ],
    "issuer": "{{ here }}"
  }
}
