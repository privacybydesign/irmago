{
  "path": "/vct/phone",
  "credentials": ["PhoneCredentialSdJwt"],
  "document": {
    "name": "Phone Credential (SD-JWT)",
    "description": "VCT metadata for phone SD-JWT credential",
    "language": "en",
    "display": [
      { "locale": "en", "name": "Phone Credential (SD-JWT)" }
    ],
    "claims": [
      {
        "path": ["phone_number"],
        "sd": "allowed",
        "display": [
          { "locale": "en", "label": "Phone Number" },
          { "locale": "nl", "label": "Telefoonnummer" }
        ]
      }
    ],
    "issuer": "https://localhost:8443/test-issuer"
  }
}
